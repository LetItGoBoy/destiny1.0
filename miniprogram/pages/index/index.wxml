<view class="page">
  <!-- 3D 星盘背景层（不参与交互） -->
  <view class="cosmos">
    <view
      class="star"
      wx:for="{{stars}}"
      wx:key="id"
      style="top:{{item.top}}%;left:{{item.left}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;animation-delay:{{item.delay}}s;animation-duration:{{item.duration}}s;"
    ></view>

    <view class="orbit-system">
      <view class="orbit orbit-1"></view>
      <view class="orbit orbit-2">
        <view class="planet"></view>
      </view>
      <view class="orbit orbit-3"></view>
    </view>

    <view class="sphere-scene">
      <view class="sphere-tilt">
        <view class="sphere">
          <view class="meridian"></view>
          <view class="meridian"></view>
          <view class="meridian"></view>
          <view class="meridian"></view>
          <view class="meridian"></view>
          <view class="meridian"></view>
          <view class="meridian"></view>
          <view class="meridian"></view>
          <view class="equator"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 前景输入 -->
  <view class="container">
    <view class="title">同乐命理</view>
    <view class="subtitle">八字排盘</view>

    <view class="panel">
      <view class="section">
        <view class="section-header">选择性别</view>
        <radio-group class="gender-selector" bindchange="onGenderChange">
          <label class="radio-label">
            <radio value="male" checked="true" color="#7aa2ff"/> 男
          </label>
          <label class="radio-label">
            <radio value="female" color="#7aa2ff"/> 女
          </label>
        </radio-group>
      </view>

      <view class="section">
        <view class="section-header">选择出生日期</view>
        <picker mode="date" bindchange="onDateChange" value="{{date}}">
          <view class="picker">{{date}}</view>
        </picker>
      </view>

      <view class="section">
        <view class="section-header">选择出生时间</view>
        <picker mode="time" bindchange="onTimeChange" value="{{time}}">
          <view class="picker">{{time}}</view>
        </picker>
      </view>
    </view>

    <button class="primary-button" bindtap="onStartPaipan">开始排盘</button>
  </view>
</view>
