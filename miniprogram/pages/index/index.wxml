<view class="page">
  <view class="header">
    <view class="title">八字排盘</view>
    <view class="subtitle">输入出生信息，即时起局</view>
  </view>

  <view class="panel">
    <!-- 姓名 -->
    <view class="field">
      <input
        class="text-input"
        placeholder="请输入姓名（选填）"
        placeholder-class="input-ph"
        bindinput="onNameInput"
        value="{{name}}"
      />
    </view>

    <!-- 性别 + 历法 -->
    <view class="seg-line">
      <view class="segment">
        <view class="seg-item {{gender === 'male' ? 'active' : ''}}" bindtap="selectGender" data-gender="male">男</view>
        <view class="seg-item {{gender === 'female' ? 'active' : ''}}" bindtap="selectGender" data-gender="female">女</view>
      </view>
      <view class="segment">
        <view class="seg-item {{calendarType === 'solar' ? 'active' : ''}}" bindtap="selectCalendar" data-type="solar">公历</view>
        <view class="seg-item {{calendarType === 'lunar' ? 'active' : ''}}" bindtap="selectCalendar" data-type="lunar">农历</view>
      </view>
    </view>

    <!-- 出生日期 -->
    <picker mode="date" bindchange="onDateChange" value="{{date}}">
      <view class="field row">
        <text class="field-label">出生日期</text>
        <view class="field-value">
          <text>{{date}}</text>
          <text class="chevron">›</text>
        </view>
      </view>
    </picker>

    <!-- 出生时间 -->
    <picker mode="time" bindchange="onTimeChange" value="{{time}}">
      <view class="field row">
        <text class="field-label">出生时间</text>
        <view class="field-value">
          <text>{{time}}</text>
          <text class="chevron">›</text>
        </view>
      </view>
    </picker>

    <!-- 出生地 -->
    <view class="field">
      <input
        class="text-input"
        placeholder="出生地 省/市（选填，用于真太阳时）"
        placeholder-class="input-ph"
        bindinput="onLocationInput"
        value="{{location}}"
      />
    </view>

    <!-- 开关 -->
    <view class="field toggle-row">
      <view class="toggle-cell">
        <text class="toggle-label">真太阳时</text>
        <switch checked="{{isTrueSolarTime}}" bindchange="onTrueSolarTimeChange" color="#c79a2e" />
      </view>
      <view class="toggle-cell">
        <text class="toggle-label">保存记录</text>
        <switch checked="{{saveToRecord}}" bindchange="onSaveToRecordChange" color="#c79a2e" />
      </view>
    </view>
  </view>

  <!-- 即时起局预览：显示此刻（页面加载时）的四柱，不随出生日期变化 -->
  <view class="preview" wx:if="{{preview}}">
    <view class="preview-pillars">
      <view class="pp-col" wx:for="{{preview}}" wx:key="stem">
        <text class="pp-gz {{item.stemClass}}">{{item.stem}}</text>
        <text class="pp-gz {{item.branchClass}}">{{item.branch}}</text>
        <text class="preview-solar">{{item.label}}</text>
      </view>
    </view>
    <view class="preview-side">
      <view>即时起局</view>
      <view class="preview-time">{{previewSolar}}</view>
    </view>
  </view>

  <button class="cta" bindtap="onStartPaipan" hover-class="cta-hover">开始排盘</button>

  <!-- 功能入口 -->
  <view class="tools">
    <view class="tool-card" hover-class="tool-hover" bindtap="onMatch" data-type="love">
      <view class="tool-icon">💕</view>
      <view class="tool-name">姻缘配对</view>
      <view class="tool-desc">两人八字合婚</view>
    </view>
    <view class="tool-card" hover-class="tool-hover" bindtap="onMatch" data-type="partner">
      <view class="tool-icon">🤝</view>
      <view class="tool-name">合伙配对</view>
      <view class="tool-desc">合作伙伴相合</view>
    </view>
  </view>
</view>
